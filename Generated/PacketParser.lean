  deriving Repr, DecidableEq, Inhabited

/-- Program state combining globals and locals. -/
abbrev ProgramState := CState Locals

/-- CSimpl body for pkt_read_byte(). -/
def pkt_read_byte_body : CSimpl ProgramState :=
  .catch
    (
      .seq
        (
          .cond (fun s => decide (s.locals.offset >= (hVal s.globals.rawHeap s.locals.buf).length))
            (
              .seq (.basic (fun s => { s with locals := { s.locals with ret__val := 1 } })) .throw
            )
            .skip
        )
        (
          .seq
            (
              .basic (fun s => { s with locals := { s.locals with idx := 0 } })
            )
            (
              .seq
                (
                  .guard (fun s => heapPtrValid s.globals.rawHeap s.locals.buf)
                    (
                      .basic (fun s => { s with locals := { s.locals with cur := (hVal s.globals.rawHeap s.locals.buf).data } })
                    )
                )
                (
                  .seq
                    (
                      .while (fun s => decide (s.locals.cur ≠ Ptr.null))
                        (
                          .seq
                            (
                              .cond (fun s => decide (s.locals.idx = s.locals.offset))
                                (
