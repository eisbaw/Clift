  hdr_len_bytes : UInt32
  hi : UInt32
  idx : UInt32
  ip : Ptr C_ipv4_header
  ip_offset : UInt32
  lo : UInt32
  offset : UInt32
  rc : UInt32
  ret__val : UInt32
