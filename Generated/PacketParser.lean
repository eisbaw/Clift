    NOTE: Locals use Inhabited default (zero-init). See task-0060. -/
structure Locals where
  actual : UInt32
  buf : Ptr C_pkt_buffer
  byte0 : UInt32
  byte1 : UInt32
  byte2 : UInt32
  byte3 : UInt32
  count : UInt32
  cur : Ptr C_pkt_byte
