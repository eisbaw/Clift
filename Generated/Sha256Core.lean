/-- Roundtrip: fromBytes (toBytes v) = v. -/
theorem C_sha256_round.fromBytes_toBytes (v : C_sha256_round) :
  C_sha256_round.fromBytes (C_sha256_round.toBytes v) = v := by
    have h_a : (fun i : Fin 4 => C_sha256_round.toBytes v ⟨0 + i.val, by omega⟩) = UInt32.toBytes' v.a := by
      funext ⟨i, hi⟩; exact C_sha256_round.toBytes_a_byte v i hi
    have h_b : (fun i : Fin 4 => C_sha256_round.toBytes v ⟨4 + i.val, by omega⟩) = UInt32.toBytes' v.b := by
      funext ⟨i, hi⟩; exact C_sha256_round.toBytes_b_byte v i hi
    have h_c : (fun i : Fin 4 => C_sha256_round.toBytes v ⟨8 + i.val, by omega⟩) = UInt32.toBytes' v.c := by
      funext ⟨i, hi⟩; exact C_sha256_round.toBytes_c_byte v i hi
    have h_d : (fun i : Fin 4 => C_sha256_round.toBytes v ⟨12 + i.val, by omega⟩) = UInt32.toBytes' v.d := by
      funext ⟨i, hi⟩; exact C_sha256_round.toBytes_d_byte v i hi
    have h_e : (fun i : Fin 4 => C_sha256_round.toBytes v ⟨16 + i.val, by omega⟩) = UInt32.toBytes' v.e := by
      funext ⟨i, hi⟩; exact C_sha256_round.toBytes_e_byte v i hi
    have h_f : (fun i : Fin 4 => C_sha256_round.toBytes v ⟨20 + i.val, by omega⟩) = UInt32.toBytes' v.f := by
      funext ⟨i, hi⟩; exact C_sha256_round.toBytes_f_byte v i hi
    have h_g : (fun i : Fin 4 => C_sha256_round.toBytes v ⟨24 + i.val, by omega⟩) = UInt32.toBytes' v.g := by
      funext ⟨i, hi⟩; exact C_sha256_round.toBytes_g_byte v i hi
    have h_h : (fun i : Fin 4 => C_sha256_round.toBytes v ⟨28 + i.val, by omega⟩) = UInt32.toBytes' v.h := by
      funext ⟨i, hi⟩; exact C_sha256_round.toBytes_h_byte v i hi
    show C_sha256_round.fromBytes (C_sha256_round.toBytes v) = v
    unfold C_sha256_round.fromBytes
    rw [h_a, h_b, h_c, h_d, h_e, h_f, h_g, h_h, UInt32.fromBytes_toBytes' v.a, UInt32.fromBytes_toBytes' v.b, UInt32.fromBytes_toBytes' v.c, UInt32.fromBytes_toBytes' v.d, UInt32.fromBytes_toBytes' v.e, UInt32.fromBytes_toBytes' v.f, UInt32.fromBytes_toBytes' v.g, UInt32.fromBytes_toBytes' v.h]
    try { cases v; rfl }

