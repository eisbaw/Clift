/-- C struct sha256_round: size=32, align=4 -/
structure C_sha256_round where
  a : UInt32
  b : UInt32
  c : UInt32
  d : UInt32
  e : UInt32
  f : UInt32
  g : UInt32
  h : UInt32
  deriving Repr, Inhabited

instance : CType C_sha256_round where
  size := 32
  align := 4
  typeTag := ⟨202⟩
  size_pos := by omega

/-- Read C_sha256_round from 32 bytes. -/
def C_sha256_round.fromBytes (f : Fin 32 → UInt8) : C_sha256_round where
  a := UInt32.fromBytes' (fun i => f ⟨0 + i.val, by omega⟩)
  b := UInt32.fromBytes' (fun i => f ⟨4 + i.val, by omega⟩)
  c := UInt32.fromBytes' (fun i => f ⟨8 + i.val, by omega⟩)
  d := UInt32.fromBytes' (fun i => f ⟨12 + i.val, by omega⟩)
  e := UInt32.fromBytes' (fun i => f ⟨16 + i.val, by omega⟩)
  f := UInt32.fromBytes' (fun i => f ⟨20 + i.val, by omega⟩)
  g := UInt32.fromBytes' (fun i => f ⟨24 + i.val, by omega⟩)
  h := UInt32.fromBytes' (fun i => f ⟨28 + i.val, by omega⟩)

/-- Write C_sha256_round to 32 bytes. -/
def C_sha256_round.toBytes (v : C_sha256_round) : Fin 32 → UInt8 := fun i =>
  if h : 0 ≤ i.val ∧ i.val < 4 then
    UInt32.toBytes' v.a ⟨i.val - 0, by omega⟩
  else
    if h : 4 ≤ i.val ∧ i.val < 8 then
      UInt32.toBytes' v.b ⟨i.val - 4, by omega⟩
    else
      if h : 8 ≤ i.val ∧ i.val < 12 then
        UInt32.toBytes' v.c ⟨i.val - 8, by omega⟩
      else
        if h : 12 ≤ i.val ∧ i.val < 16 then
          UInt32.toBytes' v.d ⟨i.val - 12, by omega⟩
        else
          if h : 16 ≤ i.val ∧ i.val < 20 then
            UInt32.toBytes' v.e ⟨i.val - 16, by omega⟩
          else
            if h : 20 ≤ i.val ∧ i.val < 24 then
              UInt32.toBytes' v.f ⟨i.val - 20, by omega⟩
            else
              if h : 24 ≤ i.val ∧ i.val < 28 then
                UInt32.toBytes' v.g ⟨i.val - 24, by omega⟩
              else
                if h : 28 ≤ i.val ∧ i.val < 32 then
                  UInt32.toBytes' v.h ⟨i.val - 28, by omega⟩
                else
                  0  -- padding bytes

