#!/usr/bin/env python3
"""clift-prove-by-claudecode: automated sorry elimination for Lean 4.

Usage:
    clift-prove-by-claudecode <file.lean>           # Process one file
    clift-prove-by-claudecode --all                  # Process entire project
    clift-prove-by-claudecode --use-claude-api       # Use Claude API (future)

Architecture:
    1. Extract: scan for sorry markers, capture goal state
    2. Prompt: build LLM prompt with context + similar proofs
    3. Apply: write tactic, run lake build, check kernel acceptance
    4. Retry: on failure, feed error back and try again (up to 3x)

The Lean kernel is the ONLY trust anchor. LLM output is always kernel-checked.
"""

import argparse
import json
import logging
import sys
from pathlib import Path

# Add project root to path
project_root = Path(__file__).parent
sys.path.insert(0, str(project_root))

from CImporter.proof_engine.extract_goals import (
    extract_sorry_static,
    extract_sorry_from_build,
    goals_to_json,
)
from CImporter.proof_engine.build_prompt import build_prompt
from CImporter.proof_engine.apply_proof import (
    apply_and_check,
    mock_llm,
    extract_tactic_from_response,
    ProofResult,
)

logger = logging.getLogger(__name__)


def process_file(filepath: str, project_dir: str,
                  max_retries: int = 3,
                  use_claude_api: bool = False,
                  lake_cmd: str = "lake",
                  dry_run: bool = False) -> list[ProofResult]:
    """Process a single .lean file: extract sorries, attempt proofs.

    Returns a list of ProofResult for each sorry encountered.
    """
    logger.info(f"Processing: {filepath}")

    # Step 1: Extract sorry goals
    goals = extract_sorry_static(filepath)
    if not goals:
        logger.info(f"No sorry found in {filepath}")
        return []

    logger.info(f"Found {len(goals)} sorry locations")

    results = []
    for goal in goals:
        logger.info(f"  Goal at {goal.file}:{goal.line} in {goal.enclosing_name or '<unknown>'}")

        if dry_run:
            results.append(ProofResult(goal=goal, success=False,
                                       tactic="(dry run)", error="dry run mode"))
            continue

        # Step 2-4: Prompt -> Apply -> Check -> Retry
        result = attempt_proof(goal, project_dir, max_retries,
                                use_claude_api, lake_cmd)
        results.append(result)

    return results


def attempt_proof(goal, project_dir: str, max_retries: int,
                   use_claude_api: bool, lake_cmd: str) -> ProofResult:
    """Attempt to prove a single sorry with retry loop."""
    error_feedback = None

    for attempt in range(1, max_retries + 1):
        logger.info(f"    Attempt {attempt}/{max_retries}")

        # Build prompt
        prompt = build_prompt(goal, error_feedback=error_feedback)

        # Get tactic from LLM
        if use_claude_api:
            # Future: call Claude API
            logger.warning("Claude API not yet implemented, using mock")
            response = mock_llm(goal, prompt.user_message)
        else:
            response = mock_llm(goal, prompt.user_message)

        tactic = extract_tactic_from_response(response)
        logger.info(f"    Tactic: {tactic[:80]}...")

        # Skip sorry-producing "proofs"
        if tactic.strip() == "sorry":
            logger.info(f"    LLM returned sorry, skipping")
            return ProofResult(goal=goal, success=False, tactic=tactic,
                              error="LLM returned sorry", attempts=attempt)

        # Apply and check
        # Determine module from file path
        module = _filepath_to_module(goal.file, project_dir)
        result = apply_and_check(goal, tactic, project_dir, module, lake_cmd)
        result.attempts = attempt

        if result.success:
            logger.info(f"    SUCCESS on attempt {attempt}")
            return result

        # Capture error for retry
        error_feedback = result.error
        logger.info(f"    Failed: {result.error[:100] if result.error else 'unknown'}")

    # All retries exhausted
    return ProofResult(goal=goal, success=False, tactic=tactic,
                      error=f"Failed after {max_retries} attempts: {error_feedback}",
                      attempts=max_retries)


def _filepath_to_module(filepath: str, project_dir: str) -> str:
    """Convert a filepath to a Lean module name.
    E.g., Examples/RingBufferProof.lean -> Examples.RingBufferProof
    """
    path = Path(filepath)
    proj = Path(project_dir)
    try:
        rel = path.relative_to(proj)
    except ValueError:
        rel = path
    # Remove .lean extension, replace / with .
    return str(rel.with_suffix("")).replace("/", ".")


def print_summary(results: list[ProofResult]) -> None:
    """Print a summary of proof results."""
    total = len(results)
    success = sum(1 for r in results if r.success)
    failed = total - success

    print(f"\n{'='*60}")
    print(f"Proof Engine Results: {success}/{total} sorries eliminated")
    print(f"{'='*60}")

    if success > 0:
        print(f"\nSucceeded ({success}):")
        for r in results:
            if r.success:
                print(f"  {r.goal.file}:{r.goal.line} ({r.goal.enclosing_name}) "
                      f"[{r.attempts} attempt(s)]")

    if failed > 0:
        print(f"\nFailed ({failed}):")
        for r in results:
            if not r.success:
                reason = r.error[:60] if r.error else "unknown"
                print(f"  {r.goal.file}:{r.goal.line} ({r.goal.enclosing_name}): {reason}")


def main():
    parser = argparse.ArgumentParser(
        description="Automated sorry elimination for Lean 4 proofs")
    parser.add_argument("file", nargs="?", help="Lean file to process")
    parser.add_argument("--all", action="store_true",
                        help="Process all sorry-containing files in project")
    parser.add_argument("--project-dir", default=".",
                        help="Project root directory (default: .)")
    parser.add_argument("--max-retries", type=int, default=3,
                        help="Max retry attempts per sorry (default: 3)")
    parser.add_argument("--use-claude-api", action="store_true",
                        help="Use Claude API for proof generation")
    parser.add_argument("--lake-cmd", default="lake",
                        help="Lake command (default: lake)")
    parser.add_argument("--dry-run", action="store_true",
                        help="Extract goals but don't attempt proofs")
    parser.add_argument("--json", action="store_true",
                        help="Output results as JSON")
    parser.add_argument("-v", "--verbose", action="store_true",
                        help="Verbose logging")

    args = parser.parse_args()

    logging.basicConfig(
        level=logging.DEBUG if args.verbose else logging.INFO,
        format="%(levelname)s: %(message)s"
    )

    if not args.file and not args.all:
        parser.error("Either provide a file or use --all")

    project_dir = str(Path(args.project_dir).resolve())

    if args.all:
        # Find all .lean files with sorry
        results = []
        for lean_file in Path(project_dir).rglob("*.lean"):
            file_results = process_file(
                str(lean_file), project_dir,
                args.max_retries, args.use_claude_api,
                args.lake_cmd, args.dry_run)
            results.extend(file_results)
    else:
        filepath = str(Path(args.file).resolve())
        results = process_file(
            filepath, project_dir,
            args.max_retries, args.use_claude_api,
            args.lake_cmd, args.dry_run)

    if args.json:
        data = [{
            "file": r.goal.file,
            "line": r.goal.line,
            "success": r.success,
            "tactic": r.tactic,
            "error": r.error,
            "attempts": r.attempts,
        } for r in results]
        print(json.dumps(data, indent=2))
    else:
        print_summary(results)


if __name__ == "__main__":
    main()
